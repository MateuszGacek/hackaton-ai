POSTGRES_USER=directus
POSTGRES_PASSWORD=directus
POSTGRES_DB=directus

DIRECTUS_PORT=8055
DIRECTUS_KEY=replace-with-at-least-32-characters-directus-key
DIRECTUS_SECRET=replace-with-at-least-32-characters-directus-secret
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=admin1234

FRONTEND_PORT=3000
# Dockerized frontend should use the Docker network hostname:
NEXT_PUBLIC_DIRECTUS_URL=http://directus:8055

# Optional: set a static token if Public role read permissions are not enabled
DIRECTUS_STATIC_TOKEN=
